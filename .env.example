# ==========================================
# oiso.demo 통합 환경 변수 (.env)
# ==========================================

# 1. API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# 2. LangSmith Tracing
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=
LANGSMITH_API_KEY=

# 3. Database (FastAPI 및 LangGraph DB 검색 툴 공통 사용)
DATABASE_URL=postgresql://testuser:testpass@localhost:5432/test

# 4. AWS / MinIO Config (FastAPI 스토리지)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
MINIO_ENDPOINT_URL=http://localhost:9000
MINIO_BUCKET_NAME=images

# 5. LangGraph Server
LANGGRAPH_SERVER_URL=http://127.0.0.1:2024
