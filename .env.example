# ==========================================
# oiso.demo Environment Variables (.env)
# ==========================================

# 1. API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# 2. LangSmith Tracing
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=
LANGSMITH_API_KEY=

# 3. Database
DATABASE_URL=postgresql://testuser:testpass@localhost:5432/test

# 4. AWS / MinIO Config
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
MINIO_ENDPOINT_URL=http://localhost:9000
MINIO_BUCKET_NAME=images
S3_BUCKET_NAME=

# 5. LangGraph Server
LANGGRAPH_SERVER_URL=http://127.0.0.1:2024
